<UserControl
    x:Class="ShiJing.Views.Controls.FolderPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    d:DesignHeight="40"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- 路径显示文本，只读，超长时省略号；圆角 -->
        <Border
            Grid.Column="0"
            Margin="0,0,8,0"
            Padding="10,6"
            VerticalAlignment="Center"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="1"
            CornerRadius="6">
            <TextBlock
                x:Name="PathText"
                VerticalAlignment="Center"
                Text="{Binding SelectedPath, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                ToolTip="{Binding SelectedPath, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <!-- 外部置为 false 时文字置灰 -->
                            <DataTrigger Binding="{Binding IsPathEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- 浏览按钮：打开文件资源管理器选择目标文件夹 -->
        <Button
            Grid.Column="1"
            Click="BrowseButton_Click"
            Content="浏览" />
    </Grid>
</UserControl>
