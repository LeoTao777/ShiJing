<Window
    x:Class="ShiJing.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:ShiJing.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sub="clr-namespace:ShiJing.Views.SubPages.TopModules"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title=""
    Width="900"
    Height="600"
    ui:TitleBar.Height="36"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Background>
        <RadialGradientBrush Center="0.5, 0.3" GradientOrigin="0.5, 0.3" RadiusX="0.7" RadiusY="0.7">
            <GradientStop Offset="0.0" Color="#FFF" />
            <GradientStop Offset="1.0" Color="#EBF1FF" />
        </RadialGradientBrush>
    </Window.Background>

    <ui:NavigationView
        x:Name="NavigationView_Root"
        IsPaneOpen="False"
        SelectionChanged="NavigationView_SelectionChanged">

        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem x:Name="NavigationViewItem_Home" Content="Home">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Home}" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem x:Name="NavigationViewItem_Video" Content="Video">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Video}" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <ui:Frame x:Name="Frame_Main" />

        <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem x:Name="NavigationViewItem_Settings" Content="Settings">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem x:Name="NavigationViewItem_About" Content="About">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Info}" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
        </ui:NavigationView.FooterMenuItems>

    </ui:NavigationView>

</Window>
