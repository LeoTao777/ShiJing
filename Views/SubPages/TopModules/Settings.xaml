<UserControl
    x:Class="ShiJing.Views.SubPages.TopModules.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:ShiJing.Views.SubPages.TopModules"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:ShiJing.ViewModels.Settings"
    d:DataContext="vm:SettingsViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <ui:ScrollViewerEx
            Grid.Row="1"
            Padding="59,0,59,0"
            ui:FocusVisualHelper.UseSystemFocusVisuals="False"
            IsTabStop="False"
            VerticalScrollBarVisibility="Auto">
            <ikw:SimpleStackPanel Spacing="4">
                <TextBlock Margin="0,16,10,5" Text="日志设置" />
                <ui:SettingsCard Header="是否开启日志记录">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE799;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch IsOn="{Binding settingsModel.Logger.IsEnabled, Mode=TwoWay}" />
                </ui:SettingsCard>

                <ui:SettingsCard
                    x:Name="LoggerLevelCard"
                    Description="设置日志输出等级，低于此等级的日志将不会输出"
                    Header="日志输出等级"
                    IsEnabled="{Binding settingsModel.Logger.IsEnabled}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE799;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ComboBox ItemsSource="{Binding LogLevelValues}" SelectedItem="{Binding settingsModel.Logger.MinLevel, Mode=TwoWay}" />
                </ui:SettingsCard>
            </ikw:SimpleStackPanel>




        </ui:ScrollViewerEx>
    </Grid>
</UserControl>
